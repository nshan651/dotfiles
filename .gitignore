# Ignore everything by default
*

# Ignore all submodules
**/.git

# Allowlist 
# We need this to explicitly check subfolders
!*/

# Allow .git and this .gitignore, of course
# Need the double "**" wildcards to propagate recursively
!.git/**
!.gitignore

# Makefile for building and installing
!Makefile
# README
!README.md

# Shell symlinks
!.xprofile
!.zprofile

# XDG
!.config/user-dirs.dirs
!.config/user-dirs.locale

# nvim
!.config/nvim/init.vim
!.config/nvim/minimal.vim

# Config
!.config/aqemu/**
!.config/bash/**
!.config/firefox/**
!.config/flameshot/**
!.config/fontconfig/**
!.config/GIMP/**
!.config/git/**
!.config/gtk-2.0/**
!.config/gtk-3.0/**
!.config/htop/**
!.config/lf/**
!.config/mozilla/**
!.config/mpd/**
!.config/mpv/**
!.config/ncmpcpp/**
!.config/neofetch/**
!.config/newsboat/**
!.config/pass-git-helper/**
!.config/pcmanfm/**
!.config/python/**
!.config/shell/**
!.config/sxhkd/**
!.config/tmux/**
!.config/tmuxinator/**
!.config/x11/**
!.config/zathura/**
!.config/zsh/**

# Scripts
!.local/bin/*
!.local/bin/statusbar/*
