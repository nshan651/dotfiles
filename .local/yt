#!/bin/sh
# Script for downloading yt channels using yt-dlp

CHANNELS="/media/yt-inbox/channels"
SUBS_LIST="$XDG_VIDEOS_DIR/subs.txt"

while IFS=',' read -r CHANNEL_NAME URL; do
    # Download the 5 most recent thumbnails and video titles
    # yt-dlp --playlist-end 3 --write-thumbnail --skip-download -o "$CHANNELS/"$CHANNEL_NAME"/%(upload_date)s_%(title)s_%(id)s.%(ext)s" "$URL"
    yt-dlp --playlist-end 3 -o "$CHANNELS/"$CHANNEL_NAME"/%(upload_date)s_%(title)s_%(id)s.%(ext)s" "$URL"

    # Clean up: Keep only the 10 most recent files (both jpg and webp)
    # find "$CHANNELS/$CHANNEL_NAME" -maxdepth 1 -type f \( -name '*.jpg' -o -name '*.webp' \) -exec ls -t {} + | tail -n +11 | xargs -0 rm -f

    find "$CHANNELS/$CHANNEL_NAME" -maxdepth 1 -type f \( -name '*.jpg' -o -name '*.webp' -o -name '*.mp4' -o -name '*.mkv' -o -name '*.webm' \) -exec ls -t {} + | tail -n +11 | xargs -0 rm -f
    
done < "$SUBS_LIST"
