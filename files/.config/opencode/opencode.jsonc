{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "external_directory": {
      "*": "ask",
      "/gnu/store/**": "allow"
    }
  },
  "experimental": {
    "disable_paste_summary": true
  },
  "mcp": {
    "dunnet": {
      "type": "local",
      "command": ["python3", "-u", "/home/nick/git/dunnet-mcp/mcp-server.py"],
      "enabled": true
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "ollama",
      "options": {
        "baseURL": "http://llama.gnosis.arpa/v1"
      },
      "models": {
        "qwen3:4b": {
          "name": "Qwen 3 4B",
          "tool_call": true,
          "limit": { "context": 32000, "output": 4096 }
        },
        "qwen3.5:2b": {
          "name": "Qwen 3.5 2B",
          "tool_call": true,
          "limit": { "context": 32000, "output": 4096 }
        },
        "qwen3.5:0.8b": {
          "name": "Qwen 3.5 0.8B",
          "tool_call": true,
          "limit": { "context": 16000, "output": 2048 }
        },
        "llama3.2:1b": {
          "name": "Llama 3.2 1B",
          "tool_call": true,
          "limit": { "context": 16000, "output": 2048 }
        },
        "gemma4:e2b": {
          "name": "Gemma 4 5.1B",
          "tool_call": true,
          "limit": { "context": 32000, "output": 4096 }
        }
      }
    }
  }
}
