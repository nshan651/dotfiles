#!/bin/bash
# Use in daemon-mode via: 
# nohup mons -a -x "display-handler" > /dev/null 2>&1 & 

# Handle various monitor setups with the exported $MONS_NUMBER.
case ${MONS_NUMBER} in
  1)
    mons --primary eDP1 -o
    ;;
  2)
    mons --primary eDP1 -s 
    ;;
  3)
    ${HOME}/.screenlayout/mons3.sh
    ;;
  4)
    ${HOME}/.screenlayout/mons3.sh
    ;;
  *)
    # Handle it manually
    ;;
esac

# Redisplay background
setbg &
